---
import type { App } from '../data/apps';

interface Props {
  app: App;
}

const { app } = Astro.props;
const isFlagship = app.flagship ?? false;

const statusLabel = {
  live: 'Live',
  coming: 'Coming Soon',
  oss: 'Open Source',
} as const;

const statusColor = {
  live: 'var(--color-accent-green)',
  coming: 'var(--color-accent)',
  oss: 'var(--color-accent-dark)',
} as const;

const flagshipAccent = {
  live: { rgb: '74, 222, 128', hex: '#4ade80' },
  coming: { rgb: '239, 159, 39', hex: '#EF9F27' },
  oss: { rgb: '239, 159, 39', hex: '#EF9F27' },
} as const;
---

{isFlagship ? (
  <!-- Flagship card -->
  <div
    class="group relative rounded-2xl p-8 md:p-10 border transition-all duration-300 hover:-translate-y-0.5"
    style={`background: linear-gradient(135deg, rgba(${flagshipAccent[app.status].rgb}, 0.04), rgba(13, 13, 18, 1)); border-color: rgba(${flagshipAccent[app.status].rgb}, 0.15);`}
    data-accent={flagshipAccent[app.status].rgb}
    onmouseenter={`this.style.borderColor='rgba(${flagshipAccent[app.status].rgb},0.3)';this.style.boxShadow='0 20px 60px rgba(${flagshipAccent[app.status].rgb},0.08)'`}
    onmouseleave={`this.style.borderColor='rgba(${flagshipAccent[app.status].rgb},0.15)';this.style.boxShadow='none'`}
  >
    <!-- Status badge -->
    <div class="absolute top-6 right-6">
      <span
        class="text-[0.65rem] font-semibold tracking-widest uppercase px-3 py-1 rounded-full"
        style={`background: ${statusColor[app.status]}20; color: ${statusColor[app.status]};`}
      >
        {statusLabel[app.status]}
      </span>
    </div>

    <div class="flex items-start gap-4 mb-4">
      <img
        src={app.icon}
        alt={`${app.name} icon`}
        width="64"
        height="64"
        class="rounded-2xl flex-shrink-0"
        loading="lazy"
      />
      <div>
        <p class="text-[0.65rem] font-semibold tracking-widest uppercase mb-1" style={`color: ${statusColor[app.status]};`}>
          {app.category}
        </p>
        <h3 class="text-2xl md:text-3xl font-semibold">{app.name}</h3>
      </div>
    </div>

    <p class="text-base font-light leading-relaxed mb-6" style="color: var(--color-text-secondary); max-width: 640px;">
      {app.description}
    </p>

    <!-- Platforms -->
    <div class="flex flex-wrap gap-1.5 mb-6">
      {app.platforms.map((p) => (
        <span
          class="text-[0.65rem] font-medium px-2.5 py-1 rounded-full"
          style="font-family: var(--font-mono); background: rgba(255,255,255,0.04); color: var(--color-text-secondary); border: 1px solid var(--color-border);"
        >
          {p}
        </span>
      ))}
    </div>

    <!-- Screenshots -->
    {app.screenshots && app.screenshots.length > 0 && (
      <div class="screenshots-scroll flex gap-3 overflow-x-auto pb-3 -mx-2 px-2" style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
        {app.screenshots.map((src) => (
          <img
            src={src}
            alt={`${app.name} screenshot`}
            class="h-56 md:h-72 rounded-xl flex-shrink-0 border"
            style="scroll-snap-align: start; border-color: var(--color-border);"
            loading="lazy"
          />
        ))}
      </div>
    )}

    <!-- Links -->
    {app.links.length > 0 && (
      <div class="flex gap-4 flex-wrap mt-6">
        {app.links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener"
            class="text-sm font-medium no-underline transition-colors duration-200"
            style={`color: ${link.primary ? 'var(--color-accent)' : 'var(--color-text-secondary)'};`}
            onmouseenter="this.style.opacity='0.7'"
            onmouseleave="this.style.opacity='1'"
          >
            {link.label} &rarr;
          </a>
        ))}
      </div>
    )}
  </div>
) : (
  <!-- Standard card -->
  <div
    class="group relative rounded-2xl p-6 border transition-all duration-300 hover:-translate-y-0.5"
    style="background: var(--color-bg-card); border-color: var(--color-border);"
    onmouseenter="this.style.borderColor='rgba(255,255,255,0.12)';this.style.boxShadow='0 16px 48px rgba(0,0,0,0.3)'"
    onmouseleave="this.style.borderColor='rgba(255,255,255,0.06)';this.style.boxShadow='none'"
  >
    <div class="flex items-start justify-between mb-4">
      <img
        src={app.icon}
        alt={`${app.name} icon`}
        width="48"
        height="48"
        class="rounded-xl"
        loading="lazy"
      />
      <span
        class="text-[0.6rem] font-semibold tracking-widest uppercase px-2.5 py-1 rounded-full"
        style={`background: ${statusColor[app.status]}15; color: ${statusColor[app.status]};`}
      >
        {statusLabel[app.status]}
      </span>
    </div>

    <p class="text-[0.6rem] font-semibold tracking-widest uppercase mb-1" style="color: var(--color-accent);">
      {app.category}
    </p>
    <h3 class="text-lg font-semibold mb-2">{app.name}</h3>
    <p class="text-sm font-light leading-relaxed mb-4" style="color: var(--color-text-secondary);">
      {app.description}
    </p>

    <!-- Platforms -->
    <div class="flex flex-wrap gap-1 mb-4">
      {app.platforms.map((p) => (
        <span
          class="text-[0.6rem] font-medium px-2 py-0.5 rounded-full"
          style="font-family: var(--font-mono); background: rgba(255,255,255,0.03); color: var(--color-text-tertiary); border: 1px solid var(--color-border);"
        >
          {p}
        </span>
      ))}
    </div>

    <!-- Screenshots (if present, e.g. Streamline) -->
    {app.screenshots && app.screenshots.length > 0 && (
      <div class="screenshots-scroll flex gap-2 overflow-x-auto pb-2 mb-4" style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
        {app.screenshots.map((src) => (
          <img
            src={src}
            alt={`${app.name} screenshot`}
            class="h-40 rounded-lg flex-shrink-0 border"
            style="scroll-snap-align: start; border-color: var(--color-border);"
            loading="lazy"
          />
        ))}
      </div>
    )}

    <!-- Links -->
    {app.links.length > 0 && (
      <div class="flex gap-3 flex-wrap">
        {app.links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener"
            class="text-xs font-medium no-underline transition-colors duration-200"
            style={`color: ${link.label === 'Sponsor' ? 'var(--color-accent-pink)' : link.primary ? 'var(--color-accent)' : 'var(--color-text-secondary)'};`}
            onmouseenter="this.style.opacity='0.7'"
            onmouseleave="this.style.opacity='1'"
          >
            {link.label} &rarr;
          </a>
        ))}
      </div>
    )}
  </div>
)}

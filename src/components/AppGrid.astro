---
import { apps } from '../data/apps';
import AppCard from './AppCard.astro';

const flagship = apps.find((a) => a.flagship);
const rest = apps.filter((a) => !a.flagship);
---

<section id="apps" class="max-w-6xl mx-auto px-6 py-24">
  <div class="reveal">
    <p class="text-[0.65rem] font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--color-accent);">
      Portfolio
    </p>
    <h2 class="text-4xl md:text-5xl font-normal leading-tight mb-3" style="font-family: var(--font-display);">
      Apps with intent
    </h2>
    <p class="text-base font-light leading-relaxed max-w-lg" style="color: var(--color-text-secondary);">
      Every project starts with a detailed spec and ships with polish. Here's what's live — and what's next.
    </p>
  </div>

  <div class="mt-12 space-y-6">
    <!-- Flagship -->
    {flagship && (
      <div class="reveal stagger-1">
        <AppCard app={flagship} />
      </div>
    )}

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {rest.map((app, i) => (
        <div class={`reveal stagger-${i + 2}`}>
          <AppCard app={app} />
        </div>
      ))}
    </div>
  </div>
</section>

---
const stats = [
  { value: '4', label: 'Active Projects', accent: true },
  { value: '1', label: 'Developer', accent: false },
  { value: '0', label: 'Subscriptions', accent: false },
  { value: '\u221E', label: 'Backlog Ideas', accent: true },
];
---

<section class="max-w-6xl mx-auto px-6 py-12">
  <div class="reveal grid grid-cols-2 md:grid-cols-4 border rounded-2xl overflow-hidden" style="border-color: var(--color-border);">
    {stats.map((stat, i) => (
      <div
        class:list={[
          'text-center py-8 px-4',
          i % 2 !== 0 && 'border-l',
          i >= 2 && 'border-t md:border-t-0',
          i >= 2 && 'md:border-l',
        ]}
        style="border-color: var(--color-border);"
      >
        <div
          class="text-4xl md:text-5xl font-normal leading-none mb-2"
          style={`font-family: var(--font-display); color: ${stat.accent ? 'var(--color-accent)' : 'var(--color-text-primary)'};`}
        >
          {stat.value}
        </div>
        <div class="text-xs font-medium tracking-wide" style="color: var(--color-text-tertiary);">
          {stat.label}
        </div>
      </div>
    ))}
  </div>
</section>
